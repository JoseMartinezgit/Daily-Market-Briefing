# ============================================================
#  Daily Market Briefing — API Keys
#  Copy this file to .env and fill in your keys.
# ============================================================

# --- Finnhub (Free tier: 60 calls/min) -----------------------
# Register at https://finnhub.io/register → copy the API key
FINNHUB_API_KEY=

# --- NewsAPI (Free developer tier: 100 req/day) --------------
# Register at https://newsapi.org/register → copy the API key
NEWS_API_KEY=

# --- Alpha Vantage (Free: 25 req/day) ------------------------
# Get key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# --- Marketaux (Free: 100 req/day) ---------------------------
# Register at https://www.marketaux.com/register
MARKETAUX_API_KEY=

# --- FRED / St. Louis Fed (Free, unlimited) ------------------
# Register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Anthropic (for --llm sentiment mode) --------------------
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
